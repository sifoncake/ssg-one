# LINE Messaging API Configuration
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# Supabase Configuration
# Backend (Lambda) - Use service role key with full access
SUPABASE_URL=
SUPABASE_KEY=

# Frontend (Next.js) - Use anon/public key for client-side access
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side (Next.js API Routes) - Use service role key for admin operations
SUPABASE_SERVICE_ROLE_KEY=

# API Configuration
# For local development: leave commented out (uses Next.js API route)
# For AWS Lambda: uncomment and set to your Lambda Function URL
# NEXT_PUBLIC_API_URL=

# Magic Link Configuration
# Base URL for magic link generation (used by Lambda)
# For local development: http://localhost:3001
# For production: your production URL
NEXT_PUBLIC_URL=http://localhost:3001
